    "parse_pisa_xml.py",
    "cns2coot.py",
    "clear_backup.py",
    "3d_generator_import.py",
    "dictionary_generators.py",
    "jligand.py",
    "americanisms.py",
    "group_settings.py",
]
post_list = [
    "coot_gui.py",
    "gui_hole.py",
    "gui_prosmart.py",
    "gui_add_linked_cho.py",
    "cho_restraints_from_models.py",
    "add_linked_cho.py",
    "gui_contact_score_isolated_ligand.py",
    "jligand_gui.py",
    "get_recent_pdbe.py",
    "extensions.py",
    "shelx_extensions.py",
    "enhanced_ligand.py",
    "ligand_check.py",
    "acedrg_link.py",
    "sharpen_blur.py",
    "dynamic_atom_overlaps_and_other_outliers.py",
    "interactive_nudge_residues.py",
    "gui_ligand_sliders.py",
    "find_baddies.py",
    "coot_toolbuttons.py",
    "pdbe_validation_data.py",
    "contact_score_isolated_ligand.py",
    "ligand_validation_sliders.py",
]
non_win_list = ["brute_lsqman.py"]

python_list = list(pre_list)
if os.name != 'nt':
    python_list += non_win_list

# Skip the GUI module list for now (pygtk2 is Py2-only; PyGObject port
# is a separate effort). Set BANDICOOT_LOAD_GUI_MODULES=1 to attempt.
if os.getenv('BANDICOOT_LOAD_GUI_MODULES'):
    python_list += post_list

# Locate the .py files: prefer COOT_PYTHON_DIR (set by coot.in), fall
# back to the autoconf-substituted @pkgpythondir@.
coot_python_dir = os.getenv('COOT_PYTHON_DIR')
if coot_python_dir:
    search_load_path = coot_python_dir
else:
    search_load_path = "@pkgpythondir@"


# Stubs that some modules expect to exist before being loaded
def coot_toolbar_button(button_label, cb_function, icon_name=False,
                        tooltip=False, toggle_button=False, use_button=False):
    pass


def toggle_backrub_rotamers(widget=None):
    pass


# Track load results so we can summarise at the end
_loaded = []
_failed = []


def _load_file(filename):
    """Load a single .py file into our globals, recording success/fail."""
    full = os.path.join(search_load_path, filename)
    if not os.path.isfile(full):
        _failed.append((filename, "file not found at " + full))
        return
    try:
        with open(full, "r") as fh:
            src = fh.read()
        code = compile(src, full, "exec")
        exec(code, globals())
        _loaded.append(filename)
    except SyntaxError as e:
        _failed.append((filename, "SyntaxError line %d: %s" % (e.lineno or 0, e.msg)))
    except Exception as e:
        _failed.append((filename, type(e).__name__ + ": " + str(e)))


if search_load_path:
    for coot_python_file in python_list:
        _load_file(coot_python_file)
else:
    print("BL WARNING:: no COOT_PYTHON_DIR or @pkgpythondir@ set; no modules loaded")


# One-line summary
print("[bandicoot-py] loaded %d module(s), %d failed" %
      (len(_loaded), len(_failed)))
if _failed and os.getenv("BANDICOOT_PY_VERBOSE"):
    for fname, err in _failed:
        print("  FAIL %s: %s" % (fname, err))
