# coot_load_modules.py.in -- autoconf-substituted at build time.
#
# Bandicoot v0.1.0.0 Py3 rewrite. Upstream Coot's version is Py2-only
# (print statements, execfile, pygtk2, hardcoded python2.7 paths).
# This rewrite:
#   - parses cleanly under Py3
#   - loads each module in its own try/except so a single broken file
#     doesn't disable the rest
#   - logs which files failed so we know what to port next
#   - skips pygtk (Py2-only PyGTK; Py3 would need PyGObject)
#   - reads COOT_PYTHON_DIR or falls back to @pkgpythondir@
#
# As we port more python/*.py files to Py3, they get picked up
# automatically. Set BANDICOOT_PY_VERBOSE=1 to see per-file failures.

import os
import sys
import traceback

# ---------------------------------------------------------------------
# Py2 compatibility preamble.
#
# Coot 0.9 was Py2-only, and so were many downstream tools that drive
# Coot via --script (notably Phenix's wxGUI2/Coot.py and pandda.inspect).
# Those are *distributed* scripts we can't patch -- the fix has to live
# on the Bandicoot side. We pre-populate sys.modules and builtins with
# the Py2 names so a `import cPickle` / `isinstance(x, unicode)` in any
# script Coot loads via --script just works.
#
# This runs before run_command_line_scripts() in setup_python.cc, so
# scripts loaded with --script see the shims.
import builtins
import pickle as _bandicoot_pickle
sys.modules.setdefault('cPickle', _bandicoot_pickle)
try:
    import io as _bandicoot_io
    sys.modules.setdefault('cStringIO', _bandicoot_io)
    sys.modules.setdefault('StringIO', _bandicoot_io)
except ImportError:
    pass
# Other commonly-renamed Py2 stdlib modules
try:
    import urllib.request, urllib.parse, urllib.error  # noqa: F401
    sys.modules.setdefault('urllib2', sys.modules['urllib.request'])
    sys.modules.setdefault('urlparse', sys.modules['urllib.parse'])
except ImportError:
    pass
try:
    import http.client
    sys.modules.setdefault('httplib', sys.modules['http.client'])
except ImportError:
    pass
try:
    import queue as _bandicoot_queue
    sys.modules.setdefault('Queue', _bandicoot_queue)
except ImportError:
    pass
try:
    import socketserver as _bandicoot_socketserver
    sys.modules.setdefault('SocketServer', _bandicoot_socketserver)
except ImportError:
    pass
try:
    import configparser as _bandicoot_configparser
    sys.modules.setdefault('ConfigParser', _bandicoot_configparser)
except ImportError:
    pass
try:
    import xmlrpc.server, xmlrpc.client
    sys.modules.setdefault('SimpleXMLRPCServer', sys.modules['xmlrpc.server'])
    sys.modules.setdefault('xmlrpclib', sys.modules['xmlrpc.client'])
    # The Py2 class lived at SimpleXMLRPCServer.SimpleXMLRPCServer -- same in Py3
    # at xmlrpc.server.SimpleXMLRPCServer, so `from SimpleXMLRPCServer
    # import SimpleXMLRPCServer` works directly via the alias.
except ImportError:
    pass
# Py2 builtins that scripts reference unqualified
for _name, _alias in (('unicode', str), ('basestring', str),
                      ('long', int), ('raw_input', input)):
    if not hasattr(builtins, _name):
        setattr(builtins, _name, _alias)

# Permissive GTK2 stub. PyGTK 2 (the `gtk` and `gobject` modules) is
# Py2-only and not installable on Py3. Phenix's wxGUI2/Coot.py and
# similar distributed driver scripts `import gtk` for their toolbar
# widgets, but their core workflow (loading molecules + maps via
# Coot's C API after each refinement cycle) doesn't depend on the
# widgets actually doing anything. A no-op stub lets `import gtk`
# succeed, the script's __init__ runs (creating unused widgets that
# vanish into the void), and the live-update code paths reach the
# real C functions they need.
#
# Loses: Phenix's UI controls inside the Bandicoot toolbar.
# Keeps: live model/map update on each refinement cycle.
#
# To upgrade to real PyGObject (gi.repository.Gtk) bindings later,
# replace this stub with an API-translation shim that maps Py2-style
# gtk.HBox / gtk.Window / etc. to their PyGObject equivalents.
class _BandicootGtkStub(object):
    def __getattr__(self, name):
        return _BandicootGtkStub()
    def __call__(self, *args, **kwargs):
        return _BandicootGtkStub()
    def __setitem__(self, *args, **kwargs):
        pass
    def __iter__(self):
        return iter(())
    def __bool__(self):
        return False
    # numeric stand-ins so module-level constants like gtk.WINDOW_TOPLEVEL
    # can be assigned/compared without exploding
    def __int__(self):
        return 0
    def __index__(self):
        return 0

sys.modules.setdefault('gtk', _BandicootGtkStub())
sys.modules.setdefault('pygtk', _BandicootGtkStub())
sys.modules.setdefault('gtk.gdk', _BandicootGtkStub())
sys.modules.setdefault('pango', _BandicootGtkStub())

# gobject needs slightly more than a no-op stub. Phenix's wxGUI2/Coot.py
# uses gobject.timeout_add(250ms, callback) to drive its XML-RPC server's
# request-polling loop.
#
# We route `gobject.timeout_add` to `coot.bandicoot_python_timeout_add`,
# a C function that wraps GLib's `g_timeout_add`. This makes the callback
# fire on the GTK main thread (where the GL context lives), so RPC
# handlers that touch GL state -- the Phenix handlers call make_and_
# draw_map, close_molecule, etc. -- run correctly. An earlier threading
# implementation crashed Bandicoot the moment Phenix sent a model+map
# update, with Metal aborting on cross-thread GL access.
def _bandicoot_glib_timeout_add(interval_ms, callback, *args, **kwargs):
    """gobject.timeout_add replacement via GLib's main loop (C-bound)."""
    if args or kwargs:
        _bound_args = args
        _bound_kwargs = kwargs
        def _bound():
            return callback(*_bound_args, **_bound_kwargs)
        _target = _bound
    else:
        _target = callback
    try:
        import coot
        return coot.bandicoot_python_timeout_add(int(interval_ms), _target)
    except (ImportError, AttributeError):
        return 0  # silent no-op when C binding is missing (dev build)

def _bandicoot_glib_idle_add(callback, *args, **kwargs):
    """gobject.idle_add replacement: schedule the callback once on the
    GLib main loop. Implemented as timeout_add(0, ...) with the callback
    wrapped to return False so it fires exactly once."""
    if args or kwargs:
        _bound_args = args
        _bound_kwargs = kwargs
        def _once():
            try:
                callback(*_bound_args, **_bound_kwargs)
            finally:
                return False
    else:
        def _once():
            try:
                callback()
            finally:
                return False
    return _bandicoot_glib_timeout_add(0, _once)

def _bandicoot_glib_source_remove(_source_id):
    """gobject.source_remove: dispatch to GLib if we have a real source id."""
    # We could expose g_source_remove from C, but the only consumer in
    # practice is when a callback wants to stop itself -- which it does
    # by returning False from the callback. Most other usage is at exit
    # time when it doesn't matter. No-op for now.
    return True

class _BandicootGobjectStub(object):
    timeout_add = staticmethod(_bandicoot_glib_timeout_add)
    idle_add = staticmethod(_bandicoot_glib_idle_add)
    source_remove = staticmethod(_bandicoot_glib_source_remove)
    def __getattr__(self, name):
        return _BandicootGtkStub()
    def __call__(self, *args, **kwargs):
        return _BandicootGtkStub()

sys.modules.setdefault('gobject', _BandicootGobjectStub())
# ---------------------------------------------------------------------

